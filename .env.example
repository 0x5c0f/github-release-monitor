# Optional GitHub webhook secret (only needed if you also use webhook mode).
GITHUB_WEBHOOK_SECRET=your_github_webhook_secret

# Optional GitHub token to increase API rate limits when fetching releases.
GITHUB_TOKEN=

# API key for OpenAI-compatible provider.
OPENAI_API_KEY=your_openai_api_key

# AI model used for language detection, translation and summarization.
OPENAI_MODEL=gpt-4.1-mini

# Optional OpenAI-compatible base URL (proxy/gateway). Leave empty for default.
OPENAI_BASE_URL=

# Vercel Blob read/write token. Required for private blob access.
BLOB_READ_WRITE_TOKEN=your_blob_read_write_token

# Default repo shown on the page and used when repo query param is omitted.
DEFAULT_REPO=vercel/next.js

# Third-party repos to poll, comma-separated, e.g. "openclaw/openclaw,vercel/next.js".
WATCH_REPOS=openclaw/openclaw

# Whether cron polling includes prerelease versions.
POLL_INCLUDE_PRERELEASE=false

# Optional static secret for /api/cron/poll-releases.
# If set, supports Authorization: Bearer <CRON_SECRET> (recommended for Vercel Cron).
CRON_SECRET=change_me_cron_secret

# Number of latest version summaries to keep in Blob per repo.
RETENTION_COUNT=5

# Optional repo allowlist, comma-separated, e.g. "vercel/next.js,openai/openai-node".
ALLOWED_REPOS=

# Default latest query mode: include prerelease or not.
DEFAULT_INCLUDE_PRERELEASE=false

# Password required to login on homepage and access release APIs.
APP_LOGIN_PASSWORD=change_me

# Optional auth session ttl in seconds (default 86400).
APP_SESSION_TTL_SECONDS=86400

# Cron token generation endpoint (POST /api/auth/cron-token) uses APP_LOGIN_PASSWORD session/header auth,
# no extra env var is required. Generated token supports expiration.

# Optional token for POST /api/releases/revalidate (header: x-revalidate-token).
REVALIDATE_TOKEN=
